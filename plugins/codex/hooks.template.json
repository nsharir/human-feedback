{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-feedback __hook",
            "timeout": 10
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "agent-feedback __hook",
            "timeout": 10
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "^(Write|Edit|apply_patch|create_file|str_replace)$",
        "hooks": [
          {
            "type": "command",
            "command": "agent-feedback __hook",
            "timeout": 20
          }
        ]
      }
    ]
  }
}
